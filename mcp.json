{
  "mcpServers": {
    "openmind": {
      "command": "python",
      "args": [
        "-m",
        "gateway.mcp_server",
        "--bff-url",
        "http://127.0.0.1:3000",
        "--api-key",
        "${MINDMESH_API_KEY}"
      ],
      "env": {
        "PYTHONPATH": "X:/OpenMind-main/OpenMind-main/openmind-subnet"
      }
    }
  }
}
