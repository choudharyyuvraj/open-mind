# --- Atlas (recommended): single host + SRV ---
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- Atlas alternative: no SRV (if querySrv times out). Copy full string from Atlas UI; do NOT use only cluster0... with mongodb:// ---
# MONGODB_URI=mongodb://USER:PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/?authSource=admin&replicaSet=atlas-xxxxx-shard-0&retryWrites=true&w=majority

MONGODB_DB_NAME=openmind
AUTH_SESSION_TTL_DAYS=7

# Public SaaS mode: set BOTH to true so anyone can sign up and create API keys.
# For a locked-down internal deployment, leave these unset or false.
# AUTH_OPEN=true
# NEXT_PUBLIC_AUTH_OPEN=true

# Public site origin (optional; set when the frontend is behind a custom domain)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Gateway / memory API. Server-only: Next proxies /api/gateway/* here.
# Example: https://gateway.example.com or http://127.0.0.1:8080
# SUBNET_GATEWAY_URL=

# Pepper for hashing dashboard API keys. Use a long random string in production
# and keep it stable forever once keys exist.
# Do not change after keys exist: existing om_live_ keys will stop verifying (401).
# API_KEY_HASH_PEPPER=

# Optional: local MCP bridge (gateway.mcp_server) if you omit --api-key
# MINDMESH_API_KEY=

# Max /api/gateway/* calls per API key per UTC day (0 = unlimited)
# API_KEY_DAILY_QUOTA=100000
